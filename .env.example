# ============================================
# PetRadar Pro — Environment Variables
# ============================================

# REQUIRED for production
DATABASE_URL=postgresql://user:pass@host:5432/petradar_db
MONGO_URL=mongodb://user:pass@host:27017/petradar_health
JWT_SECRET=your-super-secret-jwt-key-change-this

# Optional
PORT=3000
LOG_LEVEL=info
NODE_ENV=production
